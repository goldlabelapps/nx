{
    "tenant": "echopay",
    "siteName": "EchoPay",
    "description": "Payment Plugin",
    "url": "https://echopay.goldlabel.pro",
    "owner": {
        "name": "James Ward",
        "email": "james@olthem.com"
    },
    "favicon": "/echopay/webp/favicon.webp",
    "avatars": {
        "light": "/echopay/svg/favicon_184791.svg",
        "dark": "/echopay/svg/favicon_FFFFFF.svg"
    },
    "images": {
        "light": "/echopay/gif/echopay_white.gif",
        "dark": "/echopay/gif/echopay.gif"
    },
    "cartridges": {
        "nxadmin": {
            "enabled": false,
            "layout": "minidrawer"
        },
        "async": {
            "enabled": false
        },
        "paywall": {
            "enabled": false
        },
        "designSystem": {
            "themeSwitching": true,
            "defaultTheme": "light",
            "themes": {
                "dark": {
                    "mode": "dark",
                    "primary": "#A5C7FF",
                    "secondary": "#FFF",
                    "background": "#184791",
                    "paper": "#2C60B3",
                    "text": "#fff",
                    "border": "#2457A9"
                },
                "light": {
                    "mode": "light",
                    "primary": "#012867",
                    "secondary": "#12418C",
                    "background": "#fff",
                    "paper": "#E7EBF2",
                    "text": "#000",
                    "border": "#C6CAD1"
                }
            }
        }
    }
}