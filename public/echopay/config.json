{
    "tenant": "echopay",
    "siteName": "EchoPay",
    "description": "Adobe Commerce Plugin",
    "url": "https://echopay.goldlabel.pro",
    "icons": {
        "light": {
            "icon": "/echopay/svg/favicon_184791.svg",
            "favicon": "/echopay/favicon.webp"
        },
        "dark": {
            "icon": "/echopay/svg/favicon_FFFFFF.svg",
            "favicon": "/echopay/favicon_w.webp"
        }
    },
    "images": {
        "light": "/echopay/gif/echopay_white.gif",
        "dark": "/echopay/gif/echopay.gif"
    },
    "cartridges": {
        "paywall": {
            "enabled": false,
            "userMode": "single",
            "email": "echopay@goldlabel.pro"
        },
        "designSystem": {
            "themeSwitching": true,
            "defaultTheme": "light",
            "themes": {
                "dark": {
                    "mode": "dark",
                    "primary": "#A5C7FF",
                    "secondary": "#FFF",
                    "background": "#184791",
                    "paper": "#1D3B6B",
                    "text": "#fff",
                    "border": "#275296"
                },
                "light": {
                    "mode": "light",
                    "primary": "#012867",
                    "secondary": "#12418C",
                    "background": "#fff",
                    "paper": "#E7EBF2",
                    "text": "#000",
                    "border": "#C6CAD1"
                }
            }
        }
    }
}