{
    "tenant": "my-tenant",
    "siteName": "My Tenant",
    "description": "Instance of NX",
    "url": "https://my-tenant.goldlabel.pro",
    "owner": {
        "name": "Goldlabel",
        "email": "goldlabel.apps@gmail.com"
    },
    "favicon": "/my-tenant/svg/favicon.svg",
    "avatars": {
        "light": "/my-tenant/svg/avatarLight.svg",
        "dark": "/my-tenant/svg/avatarDark.svg"
    },
    "images": {
        "light": "/shared/png/default.png",
        "dark": "/shared/png/default.png"
    },
    "cartridges": {
        "nxadmin": {
            "enabled": true
        },
        "async": {
            "enabled": false
        },
        "designSystem": {
            "themeSwitching": true,
            "defaultTheme": "light",
            "themes": {
                "dark": {
                    "mode": "dark",
                    "primary": "#dcfffb",
                    "secondary": "#dcfffb",
                    "background": "#073334",
                    "paper": "#022626",
                    "text": "#fff",
                    "border": "#022626"
                },
                "light": {
                    "mode": "light",
                    "primary": "#29867C",
                    "secondary": "#29867C",
                    "background": "#fff",
                    "paper": "#E7EBF2",
                    "text": "#000",
                    "border": "#C6CAD1"
                }
            }
        }
    }
}